@layouts.main()
  <div class="container exercise-page">
    <h2>
      Réponse
    </h2>
    <div class="flashcard answer-card">
      {{ card.answer }}
    </div>
    <div class="eval-buttons">
      <form action="{{ route('exercises.evaluate') }}" method="POST">
        {{ csrfField() }}
