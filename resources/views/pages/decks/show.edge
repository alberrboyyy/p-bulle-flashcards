@layouts.main()
  <div class="container">
    <div class="deck-header">
      <h1>
        Deck: {{ deck.title }}
      </h1>
      <div class="actions">
        <a href="{{ route('decks.edit', { id: deck.id }) }}" class="btn">Modifier</a>

        <form action="{{ route('decks.destroy', { id: deck.id }) }}" method="POST" style="display:inline;">
          {{ csrfField() }}
          <button
            type="submit"
            class="btn btn-danger"
            onclick="return confirm('Voulez-vous vraiment supprimer ce deck ?')"
          >
            Supprimer
          </button>
        </form>
      </div>
    </div>

    <table class="cards-table">
      <thead>
        <tr>
          <th>
            Question
          </th>
          <th>
            Réponse
          </th>
        </tr>
      </thead>
      <tbody>
        @each(card in deck.cards)
          <tr class="clickable-row">
            <td>
              {{ card.question }}
            </td>
            <td>
              {{ card.answer }}
            </td>
          </tr>
        @else
          <tr>
            <td colspan="2" class="empty-msg">
              Ce deck ne contient pas encore de cartes.
            </td>
          </tr>
        @end
      </tbody>
    </table>

    <div class="footer-actions">
      <a href="#" class="btn">Ajouter une carte</a>
    </div>
  </div>
@end
